doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title= title
        link(rel="stylesheet" href="/css/style.css")
    body
        header
            h1 La Espiga de Oro S.R.L.
            h2 Sistema de Gestión Integrado

        main(style="display: flex; justify-content: center; padding: 3rem 1rem;")
            section.card-container(style="width: 100%; max-width: 420px;")
                h3(style="margin-top: 0; text-align: center; color: var(--primary-color); font-weight: 600;") Registro de Nuevo Usuario
                p(style="text-align: center; color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;") Cree una cuenta operativa para ingresar al sistema.

                if error
                    div.pedido-danger-zone(style="background-color: #fdf2f2; border-left: 4px solid var(--danger-color); padding: 10px 15px; border-radius: 4px; margin-bottom: 1.5rem;")
                        p(style="margin: 0; color: var(--danger-color); font-size: 0.9rem; font-weight: 500;")= error
                        
                form(action="/registro" method="POST")
                    div(style="margin-bottom: 1.25rem;")
                        label(for="nombre" style="display: block; margin-bottom: 6px; font-weight: 500; font-size: 0.9rem;") Nombre de Usuario
                        input#nombre.form-control(type="text" name="nombre" placeholder="Nombre completo" required)

                    div(style="margin-bottom: 1.25rem;")
                        label(for="email" style="display: block; margin-bottom: 6px; font-weight: 500; font-size: 0.9rem;") Correo Electrónico
                        input#email.form-control(type="email" name="email" placeholder="ejemplo@laespiga.com" required)
                        
                    div(style="margin-bottom: 1.75rem;")
                        label(for="password" style="display: block; margin-bottom: 6px; font-weight: 500; font-size: 0.9rem;") Contraseña
                        input#password.form-control(type="password" name="password" placeholder="Mínimo 6 caracteres" required)
                        
                    button.btn.btn-accent(type="submit" style="width: 100%; font-weight: 600;") Crear Usuario

                hr(style="margin: 2rem 0; border: 0; border-top: 1px dashed var(--border-color);")

                div(style="text-align: center; font-size: 0.95rem;")
                    span(style="color: var(--text-muted);") ¿Ya tenés una cuenta? 
                    a(href="/login" style="font-weight: 600; color: var(--accent-color); text-decoration: none;") Volver al Login

        footer(style="text-align: center; padding: 2rem 0; color: var(--text-muted); font-size: 0.85rem;")

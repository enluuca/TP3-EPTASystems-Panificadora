doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title= title
        link(rel="stylesheet" href="/css/style.css")
    body
        header
            div.nav-container
                div
                    a(href="/inicio" style="font-weight: 700; color: white; text-decoration: none;")  Inicio
                if usuario
                    span(style="color: #f1f5f9; font-weight: 500; font-size: 0.95rem;") 👤 Operario: #{usuario}
            h1 La Espiga de Oro S.R.L.
            h2= title

        main(style="display: flex; flex-direction: column; align-items: center; padding: 3rem 1rem;")
            section.actions(style="width: 100%; max-width: 550px; margin-bottom: 1.5rem; text-align: left;")
                a.btn.btn-primary(href="/pedidos" style="font-size: 0.9rem; padding: 8px 15px;") ⬅ Volver al listado

            section.card-container(style="width: 100%; max-width: 550px;")
                h3(style="margin-top: 0; color: var(--primary-color); font-weight: 600; margin-bottom: 1.5rem;") Nueva Orden de Distribución
                
                //- Formulario que procesa el alta del pedido
                form(action="/pedidos/nuevo" method="POST")
                    
                    //- Selección de Cliente / Sucursal
                    div(style="margin-bottom: 1.5rem;")
                        label(for="sucursal" style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.95rem; color: var(--primary-color);") Seleccione la Sucursal (Cliente):
                        select#sucursal.form-control(name="sucursal" required)
                            option(value="") -- Seleccione un cliente --
                            if clientes && clientes.length > 0
                                each cliente in clientes
                                    option(value=cliente.id) #{cliente.nombre}
                            else
                                option(value="") Error: No hay clientes registrados
                    
                    //- Selección de Productos (Checkboxes Estilizados)
                    div(style="margin-bottom: 2rem;")
                        label(style="display: block; margin-bottom: 10px; font-weight: 600; font-size: 0.95rem; color: var(--primary-color);") Productos solicitados:
                        
                        if productos && productos.length > 0
                            div(style="display: flex; flex-direction: column; gap: 8px; max-height: 250px; overflow-y: auto; padding-right: 5px;")
                                each producto in productos
                                    div(style="display: flex; align-items: center; padding: 10px 12px; background: #f8fafc; border: 1px solid var(--border-color); border-radius: 6px; transition: background 0.2s;")
                                        input(type="checkbox" name="productos" value=producto.id id=`prod-${producto.id}` style="width: 18px; height: 18px; accent-color: var(--accent-color); cursor: pointer;")
                                        label(for=`prod-${producto.id}` style="display: inline-block; margin-left: 10px; font-weight: 400; color: var(--text-main); cursor: pointer; font-size: 0.95rem; flex-grow: 1;") 
                                            strong #{producto.nombre} 
                                            span(style="color: var(--success-color); font-weight: 600; margin-left: 5px;") -$#{producto.precio.toLocaleString('es-AR')}
                        else
                            p(style="color: var(--danger-color); font-weight: 500; font-size: 0.9rem;") Error: No hay productos registrados en el catálogo.

                    //- Botón de Envío
                    div(style="margin-top: 1.5rem;")
                        button.btn.btn-accent(type="submit" style="width: 100%; font-weight: 600; font-size: 1.05rem; padding: 12px;")  Guardar Pedido

        footer(style="text-align: center; padding: 3rem 0; color: var(--text-muted); font-size: 0.85rem; border-top: 1px solid var(--border-color); margin-top: 4rem;")
            p &copy; 2026 La Espiga de Oro - Sistema de Gestión Industrial
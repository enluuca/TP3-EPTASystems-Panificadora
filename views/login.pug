doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title= title
        link(rel="stylesheet" href="/css/style.css")
    body
        header
            h1 La Espiga de Oro S.R.L.
            h2 Sistema de Gestión Integrado
        main
            section(style="text-align: center; padding: 2rem; max-width: 400px; margin: 0 auto;")
                h3 Acceso Restringido
                
                if error
                    div.pedido-danger-zone(style="margin-bottom: 1rem;")
                        p= error
                        
                form(action="/login" method="POST" style="text-align: left; padding: 1.5rem; border: 1px solid #ccc; border-radius: 8px;")
                    div(style="margin-bottom: 1rem;")
                        label(for="email") Correo Electrónico
                        input#email(type="email" name="email" style="width: 100%; padding: 0.5rem;" required)
                        
                    div(style="margin-bottom: 1.5rem;")
                        label(for="password") Contraseña
                        input#password(type="password" name="password" style="width: 100%; padding: 0.5rem;" required)
                        
                    button.btn-primary(type="submit" style="width: 100%;") Iniciar Sesión

                hr(style="margin: 2rem 0; border-top: 1px solid #ddd;")
                p ¿No tenés una cuenta todavía? 
                    a(href="/registro" style="font-weight:bold;") Registrate acá
                    hr(style="margin: 25px 0; border: 0; border-top: 1px dashed #bdc3c7;")

div.panel-evaluacion(style="background-color: #f8f9fa; padding: 15px; border-radius: 6px; border: 1px solid #e2e8f0; text-align: left;")
    h4(style="margin-top: 0; color: #2c3e50; font-size: 0.95em; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px;")  Credenciales para Corrección
    
    div(style="margin-bottom: 8px; font-size: 0.9em;")
        span(style="background: #e74c3c; color: white; padding: 2px 6px; border-radius: 3px; font-size: 0.8em; font-weight: bold; margin-right: 5px;") ROL ADMIN
        br
        strong Correo: 
        span admin@laespiga.com
        br
        strong Contraseña: 
        span admin123
        
    div(style="font-size: 0.9em;")
        span(style="background: #2ecc71; color: white; padding: 2px 6px; border-radius: 3px; font-size: 0.8em; font-weight: bold; margin-right: 5px;") ROL VENDEDOR
        br
        strong Correo: 
        span vendedor@laespiga.com
        br
        strong Contraseña: 
        span vendedor123